# Local development
DATABASE_URL=sqlite:///./todosapp.db
DB_SSLMODE=require

# Render deployment with persistent disk mounted at /var/data
# DATABASE_URL=sqlite:////var/data/todosapp.db

SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=20
AUTH_COOKIE_NAME=access_token
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
